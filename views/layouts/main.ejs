<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <%- include('../partials/head') %>
</head>
<body class="page-<%= pageId || 'default' %>" data-page="<%= pageId || 'default' %>">
  <a class="skip-link" href="#main-content"><%= ui.skip %></a>
  <div class="scroll-progress" aria-hidden="true"><span data-scroll-progress></span></div>
  <div class="page-transition-overlay" aria-hidden="true"></div>
  <div class="bg-grid" aria-hidden="true"></div>
  <div class="bg-glow" aria-hidden="true"></div>
  <div class="bg-noise" aria-hidden="true"></div>

  <%- include('../partials/header') %>

  <main id="main-content" style="view-transition-name: main-content">
    <%- include('../pages/' + bodyPartial) %>
  </main>

  <%- include('../partials/footer') %>

  <button type="button" class="to-top" data-to-top aria-label="<%= ui.backTop %>">
    <%- include('../partials/icon', { name: 'arrowUp', iconClass: '' }) %>
  </button>

  <script src="/js/transitions.js?v=24"></script>
  <script src="/js/main.js?v=24"></script>
  <% if (typeof extraScripts !== 'undefined') { extraScripts.forEach(function(src) { %>
  <script src="<%= src %>"></script>
  <% }) } %>
</body>
</html>
