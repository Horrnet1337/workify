<%- include('../partials/page-hero', {
  breadcrumbs: [
    { label: ui.common.home, href: '/' },
    { label: ui.facades.breadcrumb, href: '/fasady' },
    { label: facade.title }
  ],
  pageLabel: ui.facades.pageLabel,
  pageTitle: facade.title,
  pageDesc: facade.shortDesc
}) %>

<section class="section">
  <div class="section__inner detail-layout">
    <div class="detail-main">
      <div class="detail-visual detail-visual--photo" style="background-image: url('<%= facade.image %>')"></div>
      <p class="detail-lead"><%= facade.desc %></p>

      <h2><%= ui.facades.detailRoles %></h2>
      <div class="tags">
        <% facade.roles.forEach(function(role) { %>
          <span class="tag"><%= role %></span>
        <% }) %>
      </div>

      <h2><%= ui.facades.clientsTitle %></h2>
      <ul class="benefit-list">
        <% facade.clients.forEach(function(client) { %>
          <li><%= client %></li>
        <% }) %>
      </ul>

      <div class="detail-actions">
        <a href="/kontakt?division=fasady" class="btn btn--primary"><%= ui.facades.askQuote %></a>
        <a href="/fasady" class="btn btn--ghost"><%= ui.facades.breadcrumb %></a>
      </div>
    </div>

    <% if (related.length) { %>
      <aside class="detail-sidebar">
        <h3><%= ui.facades.breadcrumb %></h3>
        <% related.forEach(function(item) { %>
          <a href="/fasady/<%= item.slug %>" class="sidebar-link">
            <strong><%= item.title %></strong>
            <span><%= item.shortDesc %></span>
          </a>
        <% }) %>
      </aside>
    <% } %>
  </div>
</section>

<%- include('../partials/cta-banner') %>
