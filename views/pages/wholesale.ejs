<%- include('../partials/inner-hero', {
  heroEyebrow: loc.wholesalePage.eyebrow,
  heroTitle: loc.wholesalePage.title,
  heroSub: loc.wholesalePage.subtitle
}) %>

<section class="section section--tight">
  <div class="container">
    <div class="card-grid card-grid--3" data-reveal-children data-stagger="80">
      <% loc.materials.forEach(function(m, i) { %>
        <div class="card">
          <span class="card__index"><%= String(i + 1).padStart(2, '0') %></span>
          <span class="card__icon"><%- include('../partials/icon', { name: m.icon }) %></span>
          <h3 class="card__title"><%= m.title %></h3>
          <p class="card__desc"><%= m.desc %></p>
        </div>
      <% }) %>
    </div>
  </div>
</section>
