<%- include('../partials/inner-hero', {
  heroEyebrow: loc.facadesPage.eyebrow,
  heroTitle: loc.facadesPage.title,
  heroSub: loc.facadesPage.subtitle
}) %>

<section class="section section--tight">
  <div class="container">
    <div class="card-grid" data-reveal-children data-stagger="70">
      <% loc.facades.forEach(function(f, i) { %>
        <div class="card">
          <span class="card__index"><%= String(i + 1).padStart(2, '0') %></span>
          <span class="card__icon"><%- include('../partials/icon', { name: f.icon }) %></span>
          <h3 class="card__title"><%= f.title %></h3>
          <p class="card__desc"><%= f.desc %></p>
        </div>
      <% }) %>
    </div>
  </div>
</section>
