<%-
  include('../partials/page-hero', {
    breadcrumbs: [
      { label: ui.common.home, href: '/' },
      { label: ui.industries.breadcrumb, href: '/branze' },
      { label: industry.title }
    ],
    pageLabel: ui.industryDetail.industryLabel,
    pageTitle: industry.title,
    pageDesc: industry.shortDesc
  })
%>

<section class="section">
  <div class="section__inner detail-layout">
    <div class="detail-main">
      <div class="detail-visual detail-visual--photo" style="background-image: url('<%= industry.image %>')"></div>
      <p class="detail-lead"><%= industry.desc %></p>

      <h2><%= ui.industryDetail.rolesTitle %></h2>
      <div class="tags">
        <% industry.roles.forEach(function(role) { %>
          <span class="tag"><%= role %></span>
        <% }) %>
      </div>

      <div class="detail-actions">
        <a href="/kontakt" class="btn btn--primary"><%= ui.industryDetail.askStaff %></a>
        <a href="/uslugi" class="btn btn--ghost"><%= ui.industryDetail.seeServices %></a>
      </div>
    </div>

    <% if (related.length) { %>
      <aside class="detail-sidebar">
        <h3><%= ui.industryDetail.otherIndustries %></h3>
        <% related.forEach(function(item) { %>
          <a href="/branze/<%= item.slug %>" class="sidebar-link">
            <strong><%= item.title %></strong>
            <span><%= item.shortDesc %></span>
          </a>
        <% }) %>
      </aside>
    <% } %>
  </div>
</section>

<%- include('../partials/cta-banner') %>
