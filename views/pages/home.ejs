<section class="hero">
  <div class="hero__bg" aria-hidden="true"></div>
  <div class="hero__overlay" aria-hidden="true">
    <div class="hero__ellipse hero__ellipse--left"></div>
    <div class="hero__ellipse hero__ellipse--right"></div>
  </div>

  <div class="hero__container">
    <div class="hero__content">
      <div class="hero__badge">
        <div class="hero__avatars" aria-hidden="true">
          <img class="hero__avatar" src="/images/avatars/avatar-1.jpg" alt="" width="28" height="28" loading="eager" decoding="async">
          <img class="hero__avatar" src="/images/avatars/avatar-2.jpg" alt="" width="28" height="28" loading="eager" decoding="async">
          <img class="hero__avatar" src="/images/avatars/avatar-3.jpg" alt="" width="28" height="28" loading="eager" decoding="async">
          <img class="hero__avatar" src="/images/avatars/avatar-4.jpg" alt="" width="28" height="28" loading="eager" decoding="async">
        </div>
        <div class="hero__badge-stat">
          <span class="hero__badge-num">500+</span>
          <span class="hero__badge-label"><%= ui.home.badgeLabel %></span>
        </div>
      </div>

      <h1 class="hero__title">
        <%= ui.home.heroTitle1 %>&nbsp;<strong><%= ui.home.heroTitle2 %></strong>
      </h1>

      <p class="hero__subtitle">
        <%= ui.home.heroSubtitle %>
      </p>

      <div class="hero__actions">
        <a href="/kontakt" class="btn btn--primary"><%= ui.common.requestQuote %></a>
        <a href="/uslugi" class="btn btn--outline-white"><%= ui.common.ourServices %></a>
      </div>

      <div class="hero__industries">
        <p class="hero__industries-label"><%= ui.home.industryLabel %> <strong><%= ui.home.industryLabelStrong %></strong></p>
        <form class="industry-picker" action="/branze" method="get" id="industry-picker">
          <div class="industry-picker__field">
            <div class="industry-picker__dropdown" data-industry-dropdown>
              <button
                type="button"
                class="industry-picker__trigger"
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-label="<%= ui.home.industryPickAria %>"
                id="industry-picker-trigger"
              >
                <span class="industry-picker__value is-placeholder"><%= ui.home.industryPlaceholder %></span>
                <span class="industry-picker__chevron" aria-hidden="true">
                  <svg width="12" height="7" viewBox="0 0 12 7" fill="none">
                    <path d="M0.877 0.5c0.1 0 0.178.03 0.256.108L5.436 4.936l0.354 0.355 4.682-4.638c0.078-0.078 0.144-0.1 0.225-0.097 0.094 0.003 0.176 0.036 0.262 0.122 0.078 0.078 0.108 0.155 0.108 0.256 0 0.1-0.03 0.177-0.108 0.255L6.039 6.063c-0.054 0.055-0.097 0.08-0.125 0.092-0.036 0.015-0.075 0.023-0.124 0.024-0.024 0-0.047-0.003-0.067-0.007l-0.058-0.017-0.053-0.03c-0.02-0.015-0.044-0.035-0.071-0.062L0.597 1.12C0.523 1.046 0.497 0.977 0.5 0.882 0.504 0.775 0.54 0.691 0.622 0.609 0.7 0.531 0.776 0.5 0.877 0.5Z" fill="currentColor"/>
                  </svg>
                </span>
              </button>
              <input type="hidden" name="industry" value="">
              <ul class="industry-picker__menu" role="listbox" aria-labelledby="industry-picker-trigger" hidden>
                <li class="industry-picker__option is-placeholder" role="option" data-value="" aria-selected="true"><%= ui.home.industryPlaceholder %></li>
                <% industries.forEach(function(industry) { %>
                  <li class="industry-picker__option" role="option" data-value="<%= industry.slug %>"><%= industry.title %></li>
                <% }) %>
              </ul>
            </div>
          </div>
          <button type="submit" class="btn btn--primary industry-picker__submit"><%= ui.home.industryCheck %></button>
        </form>
      </div>
    </div>
  </div>
</section>

<section class="partners" aria-label="<%= ui.home.partnersAria %>">
  <div class="partners__track">
    <% ui.home.partners.forEach(function(partner) { %>
      <span class="partners__item"><%= partner %></span>
    <% }) %>
  </div>
</section>

<%- include('../partials/clients-strip') %>

<section class="section">
  <div class="section__inner">
    <div class="section__header section__header--center">
      <span class="section__label"><%= ui.home.statsLabel %></span>
      <h2 class="section__title"><%= ui.home.statsTitle %></h2>
    </div>
    <div class="stats-grid">
      <% stats.forEach(function(stat) { %>
        <div class="stat-card">
          <span class="stat-card__value"><%= stat.value %></span>
          <span class="stat-card__label"><%= stat.label %></span>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="section section--alt">
  <div class="section__inner">
    <div class="section__header section__header--center">
      <span class="section__label"><%= ui.home.servicesLabel %></span>
      <h2 class="section__title"><%= ui.home.servicesTitle %></h2>
      <p class="section__desc"><%= ui.home.servicesDesc %></p>
    </div>
    <div class="services-grid">
      <% services.forEach(function(service, i) { %>
        <a href="/uslugi/<%= service.slug %>" class="service-card">
          <div class="service-card__bg" style="background-image: url('<%= service.image %>')"></div>
          <div class="service-card__content">
            <span class="service-card__num"><%= service.num %></span>
            <h3><%= service.title %></h3>
            <p><%= service.shortDesc %></p>
            <span class="card-link"><%= ui.common.learnMore %></span>
          </div>
        </a>
      <% }) %>
    </div>
    <div class="section__action">
      <a href="/uslugi" class="btn btn--ghost"><%= ui.common.seeAllServices %></a>
    </div>
  </div>
</section>

<section class="section">
  <div class="section__inner">
    <div class="section__header section__header--center">
      <span class="section__label"><%= ui.home.industriesLabel %></span>
      <h2 class="section__title"><%= ui.home.industriesTitle %></h2>
    </div>
    <div class="industries-grid">
      <% industries.forEach(function(industry) { %>
        <a href="/branze/<%= industry.slug %>" class="industry-card">
          <div class="industry-card__visual" style="background-image: url('<%= industry.image %>')"></div>
          <div class="industry-card__content">
            <h3><%= industry.title %></h3>
            <p><%= industry.shortDesc %></p>
          </div>
        </a>
      <% }) %>
    </div>
    <div class="section__action">
      <a href="/branze" class="btn btn--ghost"><%= ui.common.seeAllIndustries %></a>
    </div>
  </div>
</section>

<section class="section section--alt">
  <div class="section__inner">
    <div class="home-cta">
      <div>
        <span class="section__label"><%= ui.home.forBusiness %></span>
        <h2 class="section__title"><%= ui.home.whyWorkify %></h2>
        <p class="section__desc"><%= ui.home.whyDesc %></p>
      </div>
      <div class="home-cta__actions">
        <a href="/jak-dzialamy" class="btn btn--ghost"><%= ui.common.howWeWork %></a>
        <a href="/kontakt" class="btn btn--primary"><%= ui.common.contactUs %></a>
      </div>
    </div>
  </div>
</section>

<%- include('../partials/cta-banner') %>
