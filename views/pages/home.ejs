<% var hero = loc.hero; %>
<% var accents = ['accent-gold','accent-amber','accent-ember','accent-bronze','accent-champagne']; %>
<section class="hero">
  <div class="hero__orb hero__orb--1" data-parallax="0.06"></div>
  <div class="hero__orb hero__orb--2" data-parallax="0.04"></div>
  <div class="hero__orb hero__orb--3" data-parallax="0.08"></div>
  <div class="container hero__inner">
    <p class="hero__badge" data-reveal>
      <span class="dot"></span><%= hero.eyebrow %>
    </p>

    <h1 class="hero__title">
      <span class="hero__line" data-reveal><span><%= hero.title %></span></span>
      <span class="hero__line accent" data-reveal style="--reveal-delay: 0.12s"><span><%= hero.accent %></span></span>
    </h1>

    <p class="hero__sub" data-reveal style="--reveal-delay: 0.24s"><%= hero.subtitle %></p>

    <div class="hero__actions" data-reveal style="--reveal-delay: 0.34s">
      <a href="/uslugi" class="btn btn--primary">
        <%= hero.primaryCta %>
        <%- include('../partials/icon', { name: 'arrow' }) %>
      </a>
      <a href="/fasady" class="btn btn--ghost"><%= hero.secondaryCta %></a>
    </div>

    <div class="hero__stats" data-reveal-children data-stagger="110" style="margin-top: clamp(48px, 7vw, 80px)">
      <% hero.stats.forEach(function(s) { %>
        <div class="hero__stat">
          <div class="hero__stat-value"><span data-count="<%= s.value %>">0</span><span class="suffix"><%= s.suffix %></span></div>
          <div class="hero__stat-label"><%= s.label %></div>
        </div>
      <% }) %>
    </div>

    <div class="hero__scroll" data-reveal>
      <span class="hero__scroll-track"></span><%= hero.scroll %>
    </div>
  </div>
</section>

<%- include('../partials/clients-marquee') %>

<!-- ABOUT -->
<section class="section accent-champagne">
  <div class="container about__grid">
    <div data-reveal>
      <p class="eyebrow"><%= loc.about.eyebrow %></p>
      <h2 class="section-title"><%= loc.about.title %></h2>
      <p class="about__lead"><%= loc.about.lead %></p>
      <div class="about__text">
        <% loc.about.paragraphs.forEach(function(p) { %><p><%= p %></p><% }) %>
      </div>
    </div>
    <div class="about__points" data-reveal-children data-stagger="100">
      <% loc.about.points.forEach(function(point) { %>
        <div class="about__point">
          <span class="about__point-check"><%- include('../partials/icon', { name: 'check' }) %></span>
          <span><%= point %></span>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- DIVISIONS -->
<section class="section section--tight section--warm accent-gold">
  <div class="container">
    <div class="section-head section-head--center" data-reveal>
      <p class="eyebrow"><%= loc.divisionsSection.eyebrow %></p>
      <h2 class="section-title"><%= loc.divisionsSection.title %></h2>
      <p class="section-sub"><%= loc.divisionsSection.subtitle %></p>
    </div>
    <div class="bento" data-reveal-children data-stagger="90">
      <% loc.divisions.forEach(function(d, i) { %>
        <a href="<%= d.href %>" class="card <%= accents[i % accents.length] %>">
          <span class="card__index"><%= String(i + 1).padStart(2, '0') %></span>
          <span class="card__icon"><%- include('../partials/icon', { name: d.icon }) %></span>
          <div>
            <h3 class="card__title"><%= d.title %></h3>
            <p class="card__desc"><%= d.desc %></p>
          </div>
          <ul class="card__points">
            <% d.points.forEach(function(p) { %>
              <li><%- include('../partials/icon', { name: 'check' }) %><%= p %></li>
            <% }) %>
          </ul>
        </a>
      <% }) %>
    </div>
  </div>
</section>

<!-- GEOGRAPHY -->
<section class="section section--line accent-amber">
  <div class="container geo__grid">
    <div data-reveal>
      <p class="eyebrow"><%= loc.geography.eyebrow %></p>
      <h2 class="section-title"><%= loc.geography.title %></h2>
      <p class="section-sub"><%= loc.geography.subtitle %></p>
      <div class="geo__cities">
        <% loc.cities.forEach(function(city) { %>
          <span class="geo__city"><%- include('../partials/icon', { name: 'pin' }) %><%= city.name %></span>
        <% }) %>
      </div>
      <p class="geo__note"><%- include('../partials/icon', { name: 'globe' }) %><%= loc.geography.note %></p>
    </div>
    <div class="geo__map" data-reveal style="--reveal-delay: 0.15s">
      <%
        var mapPoints = [
          { x: 27, y: 60, id: 'szczecin' },
          { x: 93, y: 35, id: 'gdansk' },
          { x: 65, y: 88, id: 'poznan' },
          { x: 131, y: 92, id: 'warszawa', capital: true },
          { x: 67, y: 123, id: 'wroclaw' },
          { x: 106, y: 105, id: 'lodz' },
          { x: 99, y: 146, id: 'katowice' },
          { x: 113, y: 151, id: 'krakow' },
        ];
        var cityName = {};
        loc.cities.forEach(function(c) { cityName[c.id] = c.name; });
      %>
      <svg class="geo__map-svg" viewBox="0 0 200 200" fill="none" aria-hidden="true">
        <path class="geo__map-shape" d="M22 47 L52 33 L92 28 L120 34 L159 35 L172 60 L177 96 L170 120 L158 180 L120 168 L111 175 L90 172 L65 142 L40 120 L30 99 L26 72 Z"/>
        <% mapPoints.forEach(function(p, i){ %>
          <circle class="geo__map-ping<%= p.capital ? ' is-capital' : '' %>" cx="<%= p.x %>" cy="<%= p.y %>" r="3" style="animation-delay: <%= i * 0.32 %>s"/>
          <circle class="geo__map-dot<%= p.capital ? ' is-capital' : '' %>" cx="<%= p.x %>" cy="<%= p.y %>" r="<%= p.capital ? 3.6 : 2.6 %>"><title><%= cityName[p.id] %></title></circle>
        <% }) %>
      </svg>
    </div>
  </div>
</section>
