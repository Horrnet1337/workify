<%- include('../partials/inner-hero', {
  heroEyebrow: loc.cooperationPage.eyebrow,
  heroTitle: loc.cooperationPage.title,
  heroSub: loc.cooperationPage.subtitle
}) %>

<section class="section section--tight">
  <div class="container">
    <div class="card-grid card-grid--3" data-reveal-children data-stagger="80">
      <% loc.cooperation.forEach(function(c, i) { %>
        <div class="card">
          <span class="card__index"><%= String(i + 1).padStart(2, '0') %></span>
          <span class="card__icon"><%- include('../partials/icon', { name: c.icon }) %></span>
          <h3 class="card__title"><%= c.title %></h3>
          <p class="card__desc"><%= c.desc %></p>
        </div>
      <% }) %>
    </div>
  </div>
</section>
