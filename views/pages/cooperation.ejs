<%- include('../partials/inner-hero', {
  heroEyebrow: loc.cooperationPage.eyebrow,
  heroTitle: loc.cooperationPage.title,
  heroSub: loc.cooperationPage.subtitle,
  heroAccent: 'accent-ember'
}) %>

<section class="section section--tight section--warm accent-ember">
  <div class="container">
    <% var cAcc = ['accent-ember','accent-amber','accent-gold','accent-bronze','accent-champagne']; %>
    <div class="process" data-reveal-children data-stagger="90">
      <% loc.cooperation.forEach(function(c, i) { %>
        <div class="process__step <%= cAcc[i % cAcc.length] %>">
          <span class="process__num"><%= String(i + 1).padStart(2, '0') %></span>
          <div class="process__body">
            <h3><%= c.title %></h3>
            <p><%= c.desc %></p>
            <span class="process__icon"><%- include('../partials/icon', { name: c.icon }) %></span>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>
