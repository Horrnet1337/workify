<div class="admin-shell">
  <div class="admin-login">
    <a href="/" class="admin-login__logo" aria-label="Workify">
      <img src="/images/logo.png" alt="Workify" width="120" height="40">
    </a>
    <h1 class="admin-login__title">Panel zapytań</h1>
    <p class="admin-login__desc">Zaloguj się, aby zobaczyć wszystkie formularze kontaktowe.</p>

    <% if (error) { %>
      <div class="admin-alert admin-alert--error" role="alert"><%= error %></div>
    <% } %>

    <form class="admin-login__form" method="POST" action="/admin/login">
      <label class="admin-field">
        <span>Hasło</span>
        <input type="password" name="password" required autocomplete="current-password" placeholder="••••••••">
      </label>
      <button type="submit" class="btn btn--primary btn--full">Zaloguj</button>
    </form>

    <a href="/" class="admin-login__back">← Wróć na stronę</a>
  </div>
</div>
