<footer class="footer" style="view-transition-name: site-footer">
  <div class="footer__inner">
    <div class="footer__brand">
      <a href="/" class="logo logo--footer">
        <%- include('./logo') %>
      </a>
      <p class="footer__desc"><%= site.tagline %><%= ui.footer.taglineSuffix %></p>
    </div>

    <div class="footer__columns">
      <div class="footer__col">
        <strong><%= ui.footer.company %></strong>
        <a href="/o-nas"><%= ui.footer.about %></a>
        <a href="/jak-dzialamy"><%= ui.footer.process %></a>
        <a href="/faq"><%= ui.footer.faq %></a>
      </div>
      <div class="footer__col">
        <strong><%= ui.footer.offer %></strong>
        <a href="/uslugi"><%= ui.footer.services %></a>
        <a href="/branze"><%= ui.footer.industries %></a>
        <a href="/lokalizacje"><%= ui.footer.locations %></a>
      </div>
      <div class="footer__col">
        <strong><%= ui.footer.contact %></strong>
        <a href="mailto:<%= site.contact.email %>"><%= site.contact.email %></a>
        <a href="tel:<%= site.contact.phone.replace(/\s/g, '') %>"><%= site.contact.phoneDisplay %></a>
        <a href="/kontakt"><%= ui.footer.contactForm %></a>
      </div>
    </div>
  </div>
  <div class="footer__bottom">
    <p>&copy; <%= year %> <%= site.name %>. <%= ui.footer.rights %></p>
    <%- include('./powered-by') %>
  </div>
</footer>
