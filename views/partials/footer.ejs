<footer class="footer" style="view-transition-name: site-footer">
  <div class="footer__cta" data-reveal>
    <p class="eyebrow"><%= loc.cta.eyebrow %></p>
    <h2 class="footer__cta-title"><%= loc.cta.title %></h2>
    <p class="footer__cta-sub"><%= loc.cta.subtitle %></p>
    <div class="footer__cta-contacts">
      <a class="footer__contact-pill" href="mailto:<%= site.email %>">
        <%- include('./icon', { name: 'arrow', iconClass: '' }) %>
        <span><%= site.email %></span>
      </a>
      <% if (site.phone) { %>
      <a class="footer__contact-pill" href="tel:<%= site.phoneHref %>">
        <%- include('./icon', { name: 'arrow', iconClass: '' }) %>
        <span><%= site.phone %></span>
      </a>
      <% } %>
    </div>
  </div>

  <div class="footer__main">
    <div class="footer__brand">
      <a href="/" class="logo logo--footer" aria-label="<%= site.name %>">
        <%- include('./logo') %>
      </a>
      <p class="footer__tagline"><%= ui.footer.tagline %></p>
      <span class="footer__group-badge"><%= ui.footer.group %></span>
    </div>

    <nav class="footer__nav" aria-label="<%= ui.footer.navTitle %>">
      <p class="footer__col-title"><%= ui.footer.navTitle %></p>
      <ul>
        <% nav.forEach(function(item) { %>
          <li><a href="<%= item.href %>"><%= item.label %></a></li>
        <% }) %>
      </ul>
    </nav>

    <div class="footer__contact">
      <p class="footer__col-title"><%= ui.footer.contactTitle %></p>
      <a href="mailto:<%= site.email %>"><%= site.email %></a>
      <% if (site.phone) { %><a href="tel:<%= site.phoneHref %>"><%= site.phone %></a><% } %>
      <% var socials = [['linkedin', site.social.linkedin, 'LinkedIn'], ['instagram', site.social.instagram, 'Instagram'], ['facebook', site.social.facebook, 'Facebook']].filter(function(s){ return s[1]; }); %>
      <% if (socials.length) { %>
      <div class="footer__social" aria-label="<%= ui.footer.followTitle %>">
        <% socials.forEach(function(s) { %>
        <a href="<%= s[1] %>" class="footer__social-link" aria-label="<%= s[2] %>" target="_blank" rel="noopener"><%- include('./icon', { name: s[0], iconClass: '' }) %></a>
        <% }) %>
      </div>
      <% } %>
    </div>
  </div>

  <div class="footer__bottom">
    <p>© <%= year %> <%= site.name %>. <%= ui.footer.rights %></p>
  </div>
</footer>
