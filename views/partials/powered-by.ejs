<a
  class="powered-by"
  href="<%= site.credit.url %>"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Powered by <%= site.credit.name %> — Web Development"
>
  <span class="powered-by__label">Powered by</span>
  <img
    class="powered-by__logo"
    src="/images/kappa-studio.png"
    alt="<%= site.credit.name %>"
    width="120"
    height="32"
    loading="lazy"
    decoding="async"
  >
</a>
