<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="view-transition" content="same-origin">
<meta name="description" content="<%= metaDescription || site.description %>">
<title><%= title || site.name %></title>
<link rel="icon" href="/images/logo.png" type="image/png">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/main.css?v=5">
<link rel="stylesheet" href="/css/pages.css?v=5">
<link rel="stylesheet" href="/css/transitions.css?v=5">
<style id="lang-switch-critical">
  [data-lang-stage] { overflow-x: clip; }
</style>
<script>
  (function () {
    try {
      if (sessionStorage.getItem('workify_lang_switch')) {
        sessionStorage.removeItem('workify_lang_switch');
      }
    } catch (e) { /* ignore */ }
  })();
</script>
<% if (typeof extraStyles !== 'undefined') { extraStyles.forEach(function(href) { %>
<link rel="stylesheet" href="<%= href %>">
<% }) } %>
